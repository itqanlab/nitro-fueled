{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "mcp-cortex",
  "sourceRoot": "packages/mcp-cortex/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      }
    },
    "serve": {
      "executor": "nx:run-script",
      "options": {
        "script": "dev"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/index.js",
        "cwd": "packages/mcp-cortex"
      }
    }
  }
}
