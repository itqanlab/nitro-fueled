{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "session-orchestrator",
  "sourceRoot": "packages/session-orchestrator/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      }
    },
    "serve": {
      "executor": "nx:run-script",
      "options": {
        "script": "dev"
      }
    },
    "start": {
      "executor": "nx:run-script",
      "options": {
        "script": "start"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No test script configured for session-orchestrator'",
        "cwd": "packages/session-orchestrator"
      }
    }
  }
}
