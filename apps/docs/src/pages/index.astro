---
import '../styles/custom.css';
const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : base + '/';
---
<!DOCTYPE html>
<html lang="en" class="dark" style="background:#0a0e17">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Reusable AI orchestration for any project. Full PM → Architect → Build → Review pipeline with autonomous Claude sessions." />
    <title>Nitro-Fueled — AI Dev Team Orchestration</title>
    <meta name="theme-color" content="#0a0e17" />
    <style>
      /* Manual reset — Tailwind applyBaseStyles: false */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      img, video {
        max-width: 100%;
        display: block;
      }

      /* CSS custom properties */
      :root {
        --nitro-bg:            #0a0e17;
        --nitro-bg-card:       #111827;
        --nitro-bg-card-hover: #1a2332;
        --nitro-border:        #1e293b;
        --nitro-border-accent: #334155;
        --nitro-text:          #e2e8f0;
        --nitro-text-dim:      #94a3b8;
        --nitro-text-bright:   #f8fafc;
        --nitro-orange:        #f97316;
        --nitro-orange-dim:    #ff9f5f;
        --nitro-orange-pale:   #ffb078;
        --nitro-orange-glow:   rgba(249,115,22,0.15);
        --nitro-blue:          #3b82f6;
        --nitro-green:         #22c55e;
        --nitro-purple:        #a855f7;
        --nitro-cyan:          #06b6d4;
        --nitro-yellow:        #eab308;
        --nitro-stat-label:    #90a8cb;
        --nitro-hero-badge:    #ffd6bf;
        --nitro-check-item:    #a8bad8;
        --nitro-code-text:     #c9d8ef;
        --nitro-pill-text:     #dce9ff;
        --nitro-orange-glow-strong: rgba(249,115,22,0.35);
        --nitro-cyan-border:   rgba(6,182,212,0.3);
        --nitro-cyan-bg:       rgba(6,182,212,0.06);
      }

      /* Keyframes */
      @media (prefers-reduced-motion: no-preference) {
        @keyframes fadeUp {
          from { opacity: 0; transform: translateY(16px); }
          to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes softGlow {
          0%, 100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.0); }
          50%       { box-shadow: 0 0 0 8px rgba(249,115,22,0.06); }
        }
        @keyframes flowPulse {
          0%, 100% { opacity: 0.7; transform: translateX(0); }
          50%       { opacity: 1;   transform: translateX(1px); }
        }
        @keyframes floatBlobA {
          0%, 100% { transform: translate3d(0,0,0) scale(1); }
          50%       { transform: translate3d(3%,-2%,0) scale(1.08); }
        }
        @keyframes floatBlobB {
          0%, 100% { transform: translate3d(0,0,0) scale(1); }
          50%       { transform: translate3d(-3%,2%,0) scale(1.07); }
        }
        @keyframes breatheNum {
          0%, 100% { transform: translateY(0);   opacity: 0.92; }
          50%       { transform: translateY(-1px); opacity: 1; }
        }
      }

      /* Nav */
      #main-nav {
        transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
      }
      #main-nav.nav-solid {
        background: rgba(10, 14, 23, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid #1e293b;
      }

      /* Mobile menu */
      #mobile-menu {
        display: none;
      }
      #mobile-menu.open {
        display: block;
      }

      /* Blobs */
      .blob-a {
        position: fixed; top: -14vh; left: -12vw;
        width: clamp(280px, 40vw, 560px);
        height: clamp(280px, 40vw, 560px);
        border-radius: 50%;
        pointer-events: none; z-index: -1;
        filter: blur(70px); opacity: 0.2;
        background: radial-gradient(circle, rgba(6,182,212,0.22), transparent 70%);
        animation: floatBlobA 20s ease-in-out infinite;
      }
      .blob-b {
        position: fixed; right: -12vw; bottom: -18vh;
        width: clamp(280px, 40vw, 560px);
        height: clamp(280px, 40vw, 560px);
        border-radius: 50%;
        pointer-events: none; z-index: -1;
        filter: blur(70px); opacity: 0.2;
        background: radial-gradient(circle, rgba(249,115,22,0.2), transparent 70%);
        animation: floatBlobB 22s ease-in-out infinite;
      }

      /* Hero section */
      .hero-section {
        background:
          radial-gradient(120% 90% at 50% 2%, rgba(249,115,22,0.18) 0%, rgba(249,115,22,0.02) 42%, transparent 74%),
          linear-gradient(180deg, rgba(10,16,28,0.24), rgba(10,16,28,0.58));
      }

      /* Pipeline arrows */
      .pipeline-arrow {
        color: var(--nitro-orange-dim);
        font-size: 14px;
        animation: flowPulse 2s ease-in-out infinite;
      }
      .pipeline-arrow:nth-child(2) { animation-delay: 0.5s; }
      .pipeline-arrow:nth-child(3) { animation-delay: 1.0s; }
      .pipeline-arrow:nth-child(4) { animation-delay: 1.5s; }

      /* Stats */
      .hero-stat .num {
        font-size: 35px;
        font-weight: 800;
        color: var(--nitro-orange-pale);
        animation: breatheNum 4.1s ease-in-out infinite;
        display: block;
      }

      /* Scroll fade-in */
      .fade-in {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .fade-in:nth-child(1) { transition-delay: 0ms; }
      .fade-in:nth-child(2) { transition-delay: 80ms; }
      .fade-in:nth-child(3) { transition-delay: 160ms; }
      .fade-in:nth-child(4) { transition-delay: 240ms; }
      .fade-in:nth-child(5) { transition-delay: 320ms; }
      .fade-in:nth-child(6) { transition-delay: 400ms; }

      /* Code block */
      .code-block {
        background: #080c14;
        border: 1px solid var(--nitro-border);
        border-radius: 12px;
        padding: 24px;
        overflow-x: auto;
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
        font-size: 13px;
        line-height: 1.65;
        color: var(--nitro-code-text);
      }
      .code-block .ck-heading { color: var(--nitro-orange-dim); font-weight: 700; }
      .code-block .ck-heading2 { color: var(--nitro-orange-pale); font-weight: 600; }
      .code-block .ck-key { color: var(--nitro-text-dim); }
      .code-block .ck-val-feature { color: var(--nitro-green); }
      .code-block .ck-val-p1 { color: var(--nitro-orange); }
      .code-block .ck-val-medium { color: var(--nitro-cyan); }
      .code-block .ck-comment { color: #4a5a72; font-style: italic; }
      .code-block .ck-text { color: var(--nitro-code-text); }
      .code-block .ck-pipe { color: var(--nitro-border-accent); }
      .code-block .ck-check { color: var(--nitro-text-dim); }
      .code-block .ck-check-item { color: var(--nitro-check-item); }

      /* CTA section gradient */
      .cta-section {
        background: linear-gradient(135deg, rgba(249,115,22,0.12) 0%, rgba(249,115,22,0.06) 50%, rgba(59,130,246,0.08) 100%);
        border-top: 1px solid rgba(249,115,22,0.25);
        border-bottom: 1px solid rgba(249,115,22,0.15);
      }

      /* Reduced motion overrides */
      @media (prefers-reduced-motion: reduce) {
        .fade-in {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .pipeline-arrow,
        .hero-stat .num,
        .blob-a, .blob-b {
          animation: none;
        }
      }

      /* Responsive helpers */
      @media (max-width: 768px) {
        .hero-cta-row {
          flex-direction: column;
          align-items: center;
        }
        .stats-row {
          gap: 1.5rem;
        }
      }
    </style>
  </head>
  <body class="bg-nitro-bg text-nitro-text overflow-x-hidden" style="font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">

    <!-- Background blobs -->
    <div class="blob-a" aria-hidden="true"></div>
    <div class="blob-b" aria-hidden="true"></div>

    <!-- ========== SECTION 1: STICKY NAV ========== -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50">
      <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href={baseUrl} class="flex items-center text-xl font-black" aria-label="Nitro-Fueled home">
          <span class="text-nitro-orange">Nitro</span><span class="text-nitro-text-bright">-Fueled</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden md:flex items-center gap-8">
          <a href="#why" class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">Why</a>
          <a href="#how-it-works" class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">How It Works</a>
          <a href="#get-started" class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">Get Started</a>
          <a href={`${baseUrl}getting-started/`} class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">Documentation</a>
        </div>

        <!-- Right actions -->
        <div class="hidden md:flex items-center gap-3">
          <a
            href="https://github.com/iamb0ody/nitro-fueled"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Star Nitro-Fueled on GitHub"
            class="flex items-center gap-1.5 text-sm font-medium text-nitro-text-dim border border-nitro-border rounded-md px-3 py-1.5 hover:border-nitro-border-accent hover:text-nitro-text-bright transition-all"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            Star
          </a>
          <a
            href={`${baseUrl}getting-started/`}
            class="bg-nitro-orange text-nitro-bg font-semibold text-sm px-4 py-2 rounded-md hover:opacity-90 transition-opacity"
          >
            View Docs →
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="hamburger-btn"
          class="md:hidden flex flex-col gap-1.5 p-2 text-nitro-text-dim hover:text-nitro-text-bright"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
        </button>
      </div>

      <!-- Mobile menu dropdown -->
      <div id="mobile-menu" class="md:hidden bg-nitro-bg-card border-t border-nitro-border px-6 py-4">
        <div class="flex flex-col gap-4">
          <a href="#why" class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">Why</a>
          <a href="#how-it-works" class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">How It Works</a>
          <a href="#get-started" class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">Get Started</a>
          <a href={`${baseUrl}getting-started/`} class="text-sm font-medium text-nitro-text-dim hover:text-nitro-text-bright transition-colors">Documentation</a>
          <div class="flex items-center gap-3 pt-2 border-t border-nitro-border">
            <a
              href="https://github.com/iamb0ody/nitro-fueled"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 text-sm font-medium text-nitro-text-dim border border-nitro-border rounded-md px-3 py-1.5"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              Star
            </a>
            <a href={`${baseUrl}getting-started/`} class="bg-nitro-orange text-nitro-bg font-semibold text-sm px-4 py-2 rounded-md">
              View Docs →
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- ========== SECTION 2: HERO ========== -->
    <section class="hero-section relative min-h-[90vh] flex items-center pt-32 pb-24 overflow-hidden">
      <!-- Hero ambient blobs -->
      <div aria-hidden="true" style="position:absolute;top:-22vh;left:-12vw;width:44vw;height:44vw;max-width:600px;border-radius:50%;filter:blur(66px);opacity:0.26;background:radial-gradient(circle,rgba(249,115,22,0.28),transparent 70%);pointer-events:none;z-index:0"></div>
      <div aria-hidden="true" style="position:absolute;top:-8vh;right:-16vw;width:44vw;height:44vw;max-width:600px;border-radius:50%;filter:blur(66px);opacity:0.2;background:radial-gradient(circle,rgba(22,148,255,0.2),transparent 70%);pointer-events:none;z-index:0"></div>

      <div class="relative z-10 text-center max-w-[1120px] mx-auto px-6 w-full">
        <!-- Badge -->
        <div
          class="inline-block px-[18px] py-2 rounded-full mb-5"
          style="background:linear-gradient(180deg,var(--nitro-orange-glow),rgba(249,115,22,0.06));border:1px solid rgba(249,115,22,0.65);box-shadow:inset 0 0 0 1px rgba(255,165,94,0.15),0 0 28px var(--nitro-orange-glow);color:var(--nitro-hero-badge);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.6px"
        >
          Open Source · Claude Code · Autonomous Workers
        </div>

        <!-- H1 -->
        <h1
          class="mt-5"
          style="font-size:clamp(42px,6.6vw,84px);font-weight:800;letter-spacing:-2.1px;line-height:1.04;color:var(--nitro-text-bright);text-shadow:0 0 26px var(--nitro-orange-glow),0 0 74px rgba(67,134,255,0.12)"
        >
          Your AI dev team, end-to-end.
        </h1>

        <!-- Tagline -->
        <p
          class="mt-5 mx-auto max-w-[760px] leading-[1.58]"
          style="color:var(--nitro-check-item);font-size:clamp(16px,1.9vw,18px)"
        >
          Install into any project. Define tasks. Nitro-Fueled runs the full PM → Architect → Build → Review pipeline with autonomous Claude sessions — while you focus on what matters.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-cta-row mt-8 flex items-center justify-center gap-4 flex-wrap">
          <a
            href={`${baseUrl}getting-started/`}
            class="inline-flex items-center gap-2 bg-nitro-orange text-nitro-bg font-semibold px-8 py-3.5 rounded-lg text-[15px] hover:opacity-90 transition-opacity"
            style="box-shadow:0 0 24px var(--nitro-orange-glow-strong)"
          >
            Get Started →
          </a>
          <a
            href={`${baseUrl}concepts/`}
            class="inline-flex items-center gap-2 border border-nitro-border-accent text-nitro-text-dim font-semibold px-8 py-3.5 rounded-lg text-[15px] hover:border-nitro-orange hover:text-nitro-text-bright transition-all"
          >
            View Architecture
          </a>
        </div>

        <!-- Pipeline Flow Pill -->
        <div class="mt-10 flex items-center justify-center gap-2.5 flex-wrap">
          <span class="px-3 py-1.5 rounded-full border text-xs font-bold uppercase tracking-[0.72px]" style="border-color:rgba(130,166,215,0.24);background:linear-gradient(180deg,rgba(24,37,62,0.55),rgba(15,23,40,0.38));color:var(--nitro-pill-text)">Plan</span>
          <span class="pipeline-arrow" aria-hidden="true">→</span>
          <span class="px-3 py-1.5 rounded-full border text-xs font-bold uppercase tracking-[0.72px]" style="border-color:rgba(130,166,215,0.24);background:linear-gradient(180deg,rgba(24,37,62,0.55),rgba(15,23,40,0.38));color:var(--nitro-pill-text)">Design</span>
          <span class="pipeline-arrow" aria-hidden="true">→</span>
          <span class="px-3 py-1.5 rounded-full border text-xs font-bold uppercase tracking-[0.72px]" style="border-color:rgba(130,166,215,0.24);background:linear-gradient(180deg,rgba(24,37,62,0.55),rgba(15,23,40,0.38));color:var(--nitro-pill-text)">Build</span>
          <span class="pipeline-arrow" aria-hidden="true">→</span>
          <span class="px-3 py-1.5 rounded-full border text-xs font-bold uppercase tracking-[0.72px]" style="border-color:rgba(130,166,215,0.24);background:linear-gradient(180deg,rgba(24,37,62,0.55),rgba(15,23,40,0.38));color:var(--nitro-pill-text)">Review</span>
          <span class="pipeline-arrow" aria-hidden="true">→</span>
          <span class="px-3 py-1.5 rounded-full border border-nitro-green text-nitro-green text-xs font-bold uppercase tracking-[0.72px]" style="background:linear-gradient(180deg,rgba(34,197,94,0.12),rgba(34,197,94,0.04))">Complete</span>
        </div>

        <!-- Stats Row -->
        <div class="stats-row mt-10 flex justify-center gap-11 flex-wrap">
          <div class="hero-stat text-center">
            <span class="num" id="stat-tasks">55+</span>
            <span class="text-xs uppercase tracking-[1px] mt-1 block" style="color:var(--nitro-stat-label)">Tasks Shipped</span>
          </div>
          <div class="hero-stat text-center">
            <span class="num" id="stat-agents">16</span>
            <span class="text-xs uppercase tracking-[1px] mt-1 block" style="color:var(--nitro-stat-label)">Agents</span>
          </div>
          <div class="hero-stat text-center">
            <span class="num" id="stat-workflows">7</span>
            <span class="text-xs uppercase tracking-[1px] mt-1 block" style="color:var(--nitro-stat-label)">Workflow Types</span>
          </div>
          <div class="hero-stat text-center">
            <span class="num" id="stat-workers">3</span>
            <span class="text-xs uppercase tracking-[1px] mt-1 block" style="color:var(--nitro-stat-label)">Parallel Workers</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== SECTION 3: THE PROBLEM ========== -->
    <section id="why" class="fade-in">
      <div class="max-w-[1200px] mx-auto py-16 px-10">
        <p class="text-xs font-bold uppercase tracking-[2px] text-nitro-orange mb-2">Why It Exists</p>
        <h2 class="text-3xl font-bold text-nitro-text-bright mb-10">AI gives you code. Not engineering.</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Card 1 -->
          <div class="fade-in bg-nitro-bg-card border border-nitro-border rounded-xl p-6 hover:border-nitro-border-accent hover:bg-nitro-bg-card-hover transition-all duration-200" style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.05),0 8px 28px rgba(7,10,18,0.45)">
            <div class="w-10 h-10 bg-[rgba(249,115,22,0.1)] rounded-lg p-2 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-nitro-orange" aria-hidden="true">
                <circle cx="12" cy="8" r="4"/>
                <path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
                <path d="M18 8h4M20 6v4"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-nitro-text-bright mt-4 mb-2">You're still the PM, Architect, and QA</h3>
            <p class="text-sm text-nitro-text-dim leading-relaxed">Every AI tool hands you code and walks away. You still define scope, design the solution, review the output, and manage state across sessions.</p>
          </div>
          <!-- Card 2 -->
          <div class="fade-in bg-nitro-bg-card border border-nitro-border rounded-xl p-6 hover:border-nitro-border-accent hover:bg-nitro-bg-card-hover transition-all duration-200" style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.05),0 8px 28px rgba(7,10,18,0.45)">
            <div class="w-10 h-10 bg-[rgba(59,130,246,0.1)] rounded-lg p-2 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-nitro-blue" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
