{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@nitro-fueled/docs",
  "sourceRoot": "apps/docs/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      }
    },
    "serve": {
      "executor": "nx:run-script",
      "options": {
        "script": "dev"
      }
    },
    "preview": {
      "executor": "nx:run-script",
      "options": {
        "script": "preview"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No test script configured for @nitro-fueled/docs'",
        "cwd": "apps/docs"
      }
    }
  }
}
