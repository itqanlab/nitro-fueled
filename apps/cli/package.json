{
  "name": "@itqanlab/nitro-fueled",
  "version": "0.1.0",
  "description": "AI development orchestration — full PM -> Architect -> Dev -> QA pipeline",
  "type": "module",
  "bin": {
    "nitro-fueled": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "copy-web-assets": "test -d ../dashboard/dist || (echo 'Error: ../dashboard/dist not found — run: nx build dashboard' >&2 && exit 1) && rm -rf ./dashboard-assets && cp -R ../dashboard/dist ./dashboard-assets",
    "prepare-scaffold": "bash scripts/prepare-scaffold.sh",
    "prepublishOnly": "npm run prepare-scaffold && npm run build"
  },
  "keywords": [
    "ai",
    "orchestration",
    "claude",
    "development",
    "automation"
  ],
  "files": [
    "dist",
    "scaffold",
    "dashboard-assets"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "nitro-fueled",
    "dirname": "nitro-fueled",
    "commands": "./dist/commands",
    "topics": {
      "config": {
        "description": "Configure providers and validate dependencies"
      }
    }
  },
  "dependencies": {
    "@oclif/core": "^4.10.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0"
  }
}
