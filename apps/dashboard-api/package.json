{
  "name": "@nitro-fueled/dashboard-service",
  "version": "0.1.0",
  "main": "dist/cli-entry.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:spec": "ts-node -r tsconfig-paths/register scripts/generate-spec.ts",
    "start": "node dist/main.js",
    "start:dev": "PORT=3100 ts-node -r tsconfig-paths/register src/main.ts",
    "dev": "PORT=3100 node --watch-path=dist dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "better-sqlite3": "^11.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/socket.io-client": "^3.0.0",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.6",
    "typescript": "~5.6.0"
  }
}
