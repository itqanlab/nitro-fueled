{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@nitro-fueled/dashboard-service",
  "sourceRoot": "apps/dashboard-service/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      }
    },
    "serve": {
      "executor": "nx:run-script",
      "options": {
        "script": "dev"
      }
    },
    "start": {
      "executor": "nx:run-script",
      "options": {
        "script": "start"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No test script configured for @nitro-fueled/dashboard-service'",
        "cwd": "apps/dashboard-service"
      }
    }
  }
}
