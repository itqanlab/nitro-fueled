{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Volumes/SanDiskSSD/mine/nitro-fueled/.claude/hooks/sync-scaffold.sh"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; [[ \"$f\" =~ task-tracking/[^/]+/status$ ]] && npx nitro-fueled status; } 2>/dev/null || true",
            "statusMessage": "Syncing task registry..."
          }
        ]
      }
    ]
  }
}
